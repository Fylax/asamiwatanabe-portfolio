---
interface Props {
  gallery: Collection
}

const { gallery } = Astro.props;

import { getImage } from "astro:assets";
import { Schema } from "astro-seo-schema";

import Grid from "@components/Grid.astro";
import ResponsivePicture from "@components/ResponsivePicture.astro";
import type { Collection }from "../gallery";
import type { QuantitativeValue } from "schema-dts";

const works = await Promise.all(
  gallery.works.map(async (work) => {
    return Object.assign(work, {
      thumbnail: await getImage({
        src: work.file,
        format: "jpg",
        quality: 100,
        width: 500,
      }),
      fullsize: {
        avif: await getImage({
          src: work.file,
          format: "avif",
          quality: 100,
        }),
        jpeg: await getImage({
          src: work.file,
          format: "jpg",
          quality: 100,
        }),
      },
    });
  }),
);
const minWidth = works.reduce(
  (prev, curr) => (curr.file.width < prev ? curr.file.width : prev),
  Infinity,
);

const siteUrl = (
  Astro.site?.href ??
  Astro.url?.origin ??
  "http://localhost:4321"
).replace(/\/$/, "");
const pageUrl = Astro.url?.href ?? siteUrl;

const artworkIds = works.map((work, index) => `${siteUrl}#${index}${work.title.replaceAll(/\s+/g, "_").toLowerCase()}`);
---

<Schema
  item={{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": `${pageUrl}#page`,
    url: pageUrl,
    name: gallery.name as string,
    description: gallery.description as string,
    inLanguage: Astro.locals.locale,
    mainEntity: {
      "@type": "ItemList",
      itemListElement: artworkIds,
    },
  }}
/>

{
  works.map((work, index) => (
    <Schema
      item={{
        "@context": "https://schema.org",
        "@type": "VisualArtwork",
        "@id": `${siteUrl}\#${index}${work.title.replaceAll(/\s+/g, '_').toLowerCase()}`,
        creator: { 
          "@id": `${siteUrl}\#asami`
        },
        name: work.title,
        image: `${siteUrl}${work.fullsize.jpeg.src}`,
        thumbnailUrl: `${siteUrl}${work.thumbnail.src}`,
        description: work.alt,
        inLanguage: Astro.locals.locale,
        artform: "Illustration",
        artMedium: work.medium,
        material: work.materials,
        width: {
          value: work.size.width,
          unitCode: 'MM',
        } as QuantitativeValue,
        height: {
          value: work.size.height,
          unitCode: 'MM',
        } as QuantitativeValue
      }}
    />
  ))
}
<section class="section with-background">
  <header class="section-header stack gap-2 lg:gap-4">
    <h1 set:html={gallery.name}></h1>
  </header>

  <div id="gallery" class="gallery">
    <Grid>
      {
        works.map((image, index) => (
          <li
            class="hologram-container"
            data-gallery-index={index}
            data-fullsize-avif={image.fullsize.avif.src}
            data-fullsize-jpeg={image.fullsize.jpeg.src}
          >
            <a
              href={image.fullsize.jpeg.src}
              target="_blank"
              rel="noopener noreferrer"
              class="fallback-link"
            >
              <div class="picture-card">
                <ResponsivePicture
                  title={image.title}
                  altText={image.alt}
                  image={image.file}
                  width={minWidth}
                  center={true}
                  fetchPriority={index == 0 ? "high" : "low"}
                />
              </div>
            </a>
          </li>
        ))
      }
    </Grid>
  </div>
</section>

<style is:global>
  .section {
    display: grid;
    grid-template-areas: "header" "gallery";
    gap: 2rem;
  }

  .with-background {
    position: relative;
  }

  .with-background::before {
    content: "";
    position: absolute;
    pointer-events: none;
    left: 50%;
    width: 100vw;
    aspect-ratio: calc(2.25 / var(--bg-scale));
    transform: translateY(-75%) translateX(-50%);
    background:
      url("/assets/backgrounds/noise.png") top center/220px repeat,
      var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
      var(--gray-999);
    background-blend-mode: overlay, normal, normal, normal;
    mix-blend-mode: var(--bg-blend-mode);
  }

  .section-header {
    justify-self: center;
    text-align: center;
    max-width: 50ch;
    font-size: var(--text-md);
    color: var(--gray-300);
    grid-area: header;
  }

  .gallery {
    grid-area: gallery;
  }

  .section-header h1 {
    font-size: var(--text-2xl);
  }

  .hologram-container {
    display: flex;
  }

  a.fallback-link {
    width: 100%;
  }

  .picture-card {
    overflow: hidden;
    height: 10rem;
    width: 100%;
    border: 1px solid var(--gray-800);
    border-radius: 1.5rem;
    box-shadow: var(--shadow-sm);
    transition: all 0.5s ease;
  }

  @media (min-width: 50em) {
    .section {
      grid-template-columns: repeat(4, 1fr);
      grid-template-areas: "header header header header" "gallery gallery gallery gallery";
      gap: 5rem;
    }

    .section-header {
      grid-area: header;
      font-size: var(--text-lg);
    }

    .section-header h1 {
      font-size: var(--text-4xl);
    }

    .picture-card {
      height: 15rem;
    }
  }

  .picture-card::before {
    content: "";
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
      0deg,
      transparent,
      transparent 30%,
      var(--accent-overlay)
    );
    transform: rotate(-45deg);
    transition: all 0.5s ease;
    opacity: 0;
    pointer-events: none;
  }

  .picture-card:hover {
    transform: scale(1.05);
    box-shadow: 0 0 2rem var(--gradient-accent-orange);
  }

  .picture-card:hover::before {
    opacity: 1;
    transform: rotate(-45deg) translateY(100%);
  }

  .viewer-backdrop {
    background-color: #090b11 !important;
  }

  .viewer-title {
    opacity: 1 !important;
    color: #f3f4f7 !important;
  }
</style>

<script>
  import "viewerjs/dist/viewer.css";
  import Viewer from "viewerjs";

  document
    .querySelectorAll("a.fallback-link")
    .forEach((el) => el.replaceWith(...el.childNodes));

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }

  async function init() {
    const supportsAvif = await new Promise((resolve) => {
      const img = new Image();
      img.onload = () => resolve(img.width === 1);
      img.onerror = () => resolve(false);
      img.src =
        "data:image/avif;base64,";
    });

    const isTouch = window.matchMedia("(pointer: coarse)").matches;
    const viewer = new Viewer(document.getElementById("gallery")!, {
      inline: false,
      title: [3, (image: HTMLImageElement) => `${image.title} — ${image.alt}`],
      toolbar: {
        zoomIn: !isTouch,
        zoomOut: !isTouch,
        oneToOne: !isTouch,
        reset: false,
        prev: !isTouch,
        play: false,
        next: !isTouch,
        rotateLeft: false,
        rotateRight: false,
        flipHorizontal: false,
        flipVertical: false,
      },
      filter(image: HTMLImageElement) {
        return !image.classList.contains("blur");
      },
      rotatable: false,
      view(event) {
        const viewerImage = event.detail.image as HTMLImageElement;
        const originalImage = event.detail.originalImage as HTMLImageElement;
        viewerImage.title = originalImage.title; 

        const li = originalImage.closest("li") as HTMLLIElement;

        let url = null;
        if (supportsAvif) {
          url = li.dataset.fullsizeAvif;
        }
        if (!url) {
          url = li.dataset.fullsizeJpeg;
        }

        if (url) {
          viewerImage.removeAttribute("srcset");
          viewerImage.removeAttribute("sizes");
          viewerImage.removeAttribute("loading");
          viewerImage.removeAttribute("decoding");
          viewerImage.src = url;
        }
      },
      transition: false,
    });

    document.querySelectorAll(".hologram-container").forEach((element) => {
      element.addEventListener("click", (evt) => {
        viewer.view(
          parseInt((evt.currentTarget as HTMLLIElement).dataset.galleryIndex!),
        );
      });
    });
  }
</script>
