---
interface Props {
  title: string;
  altText: string;
  page: string;
  background: ImageMetadata;
}

const { title, altText, page, background } = Astro.props;

import ResponsivePicture from "@components/ResponsivePicture.astro";
---

<a href={page}>
  <section class="section">
    <header class="section-header">
      <h2 set:html={title}></h2>
    </header>

    <div class="overlay">
      <ResponsivePicture altText={altText} image={background} center={true} />
    </div>
    <div class="arrow">
      <div class="arrow-top"></div>
      <div class="arrow-bottom"></div>
    </div>
  </section>
</a>

<style is:global>
  a {
    text-decoration: none;
    position: relative;
  }

  a .section {
    border-radius: 1.5rem;
    padding: 2rem 2.5rem;
    box-shadow: var(--shadow-md);
    margin: 1rem;
    height: 10rem;
    overflow: hidden;
  }

  a .section .overlay {
    height: inherit;
    width: inherit;
    padding: 0;
    margin: inherit;
    border-radius: inherit;
    background: var(--accent-subtle-overlay);
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  a .section .overlay img {
    width: 100%;
    filter: grayscale(40%) brightness(0.75);
  }

  a .section .overlay::before {
    content: "";
    color: var(--gray-0);
    position: absolute;
    right: 0;
    width: 30%;
    height: 100%;
    background: linear-gradient(90deg, transparent, var(--gray-999) 80%);
    pointer-events: none;
    z-index: 2;
  }

  .a .section .overlay::before {
    opacity: 1;
    transform: rotate(-45deg) translateY(100%);
  }

  a .section .section-header,
  a .section .description {
    position: relative;
    z-index: 1;
  }

  a .section-header {
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
    max-width: 50ch;
    font-size: var(--text-md);
    color: var(--gray-300);
  }

  a .section-header h2 {
    font-size: var(--text-2xl);
    color: white;
  }

  @media (min-width: 50em) {
    a .section-header {
      max-width: 75ch;
    }

    a .section-header h2 {
      font-size: var(--text-3xl);
    }
  }

  @media (max-width: 50em) {
    a .section-header {
      padding-right: 15%;
    }
  }

  .arrow {
    right: 2%;
    position: absolute;
    top: 50%;
    transform: translateX(-50%) translateY(-50%);
    transition: transform 0.1s;
    width: 2rem;
    z-index: 3;
  }

  .arrow-top,
  .arrow-bottom {
    background-color: var(--gray-100);
    height: 4px;
    left: -5px;
    position: absolute;
    top: 50%;
    width: 100%;
  }

  .arrow-top:after,
  .arrow-bottom:after {
    background-color: var(--gray-400);
    content: "";
    height: 100%;
    position: absolute;
    top: 0;
    transition: all 0.15s;
  }

  .arrow-top {
    transform: rotate(45deg);
    transform-origin: bottom right;
  }

  .arrow-top:after {
    left: 100%;
    right: 0;
    transition-delay: 0s;
  }

  .arrow-bottom {
    transform: rotate(-45deg);
    transform-origin: top right;
  }

  .arrow-bottom:after {
    left: 0;
    right: 100%;
    transition-delay: 0.15s;
  }

  @media (hover: hover) {
    a .section:hover .arrow-top:after {
      left: 0;
      transition-delay: 0.15s;
    }

    a .section:hover .arrow-bottom:after {
      right: 0;
      transition-delay: 0s;
    }
  }
</style>
